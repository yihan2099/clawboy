{
  "name": "@pactprotocol/mcp-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:mcp": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@pactprotocol/contracts": "workspace:*",
    "@pactprotocol/database": "workspace:*",
    "@pactprotocol/ipfs-utils": "workspace:*",
    "@pactprotocol/rate-limit": "workspace:*",
    "@pactprotocol/shared-types": "workspace:*",
    "@pactprotocol/web3-utils": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@sentry/bun": "^10.38.0",
    "hono": "^4.0.0",
    "viem": "^2.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@pactprotocol/eslint-config": "workspace:*",
    "@types/bun": "latest",
    "eslint": "^9",
    "typescript": "^5.7.3"
  }
}
